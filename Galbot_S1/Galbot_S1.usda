            over "ROS_Odometry"
            {
                over "Context" (
                    prepend apiSchemas = ["NodeGraphNodeAPI"]
                )
                {
                    uniform float2 ui:nodegraph:node:pos = (-578.25, -37.41728)
                }

                over "ComputeOdometry"
                {
                    custom rel inputs:chassisPrim = </Galbot_S1/SteeringChassis/base_link>
                }
            }
        }

        over "base_link"
        {
        }

