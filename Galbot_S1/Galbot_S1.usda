def Xform "Galbot_S1" (
    variants = {
        string Arms = "Arms"
        string Base = "SteeringChassis"
        string Physics = "PhysX"
        string Robot = "Robot"
        string Sensor = "Sensors"
    }
    prepend variantSets = ["Physics", "Sensor", "Robot", "Base", "Arms"]
)
{
    string[] isaac:changelog (
        displayName = "Changelog"
    )
    string isaac:description (
        displayName = "Description"
    )
    token isaac:license (
        displayName = "License"
    )
    string isaac:namespace (
        displayName = "Namespace"
    )
    rel isaac:physics:robotJoints (
        displayName = "Robot Joints"
    )
    rel isaac:physics:robotLinks (
        displayName = "Robot Links"
    )
    token isaac:robotType (
        displayName = "Robot Type"
    )
    string isaac:source (
        displayName = "Source"
    )
    string isaac:version (
        displayName = "Version"
    )

    over "base_link"
    {
        over "column_base_link"
        {
            over "column_lidar"
            {
                def "mid360" (
                    prepend payload = @../../../sensors/mid360.usd@
                )
                {
                    quatf xformOp:orient = (1, 0, 0, 0)
                    double xformOp:rotateX:unitsResolve = 90
                    float3 xformOp:scale = (1, 1, 1)
                    double3 xformOp:translate = (0, 0, 0)
                    uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:orient", "xformOp:scale", "xformOp:rotateX:unitsResolve"]
                }
            }
        }
    }

    over "torso_lift_link1"
    {
    }

    over "head_link1"
    {
    }

    over "head_link2"
    {
        over "head_end_effector_mount_link"
        {
            over "head_lidar"
            {
                def "mid360" (
                    prepend payload = @../../../sensors/mid360.usd@
                )
                {
                    quatf xformOp:orient = (1, 0, 0, 0)
                    double xformOp:rotateX:unitsResolve = 90
                    float3 xformOp:scale = (1, 1, 1)
                    double3 xformOp:translate = (0, 0, 0)
                    uniform token[] xformOpOrder = ["xformOp:translate", "xformOp:orient", "xformOp:scale", "xformOp:rotateX:unitsResolve"]
                }
            }
        }
    }

    over "joints"
    {
        over "body_joint"
        {
            float state:linear:physics:position = 0
            float state:linear:physics:velocity = 0
        }

        over "head_joint1"
        {
            bool[] isaac:actuator (
                displayName = "Actuator"
            )
            string isaac:NameOverride (
                displayName = "Joint Name Override"
            )
            token[] isaac:physics:DofOffsetOpOrder (
                displayName = "Dof Offset Op Order"
            )
            float state:angular:physics:position = 0
            float state:angular:physics:velocity = 0
        }

        over "head_joint2"
        {
            float state:angular:physics:position = 0
            float state:angular:physics:velocity = 0
        }
    }

    over "SteeringChassis"
    {
        over "Graph"
        {
            over "steering_wheel_controller"
            {
                over "articulation_controller"
                {
                    custom rel inputs:targetPrim = </Galbot_S1>
