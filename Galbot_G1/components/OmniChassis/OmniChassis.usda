    variantSet "Physics" = {
        "None" (
            prepend references = @./configuration/OmniChassis_base.usd@
        ) {
            over "joints" (
                active = false
            )
            {
            }

        }
        "PhysX" (
            prepend payload = @./configuration/OmniChassis_physics.usd@
        ) {

        }
    }
    variantSet "Sensor" = {
        "None" {

        }
        "Sensors" (
            prepend payload = @./configuration/OmniChassis_sensor.usd@
        ) {

        }
    }
    variantSet "Robot" = {
        "None" {

        }
        "Robot" (
            prepend payload = @./configuration/OmniChassis_robot.usd@
        ) {

        }
    }
    variantSet "Wheel1" = {
        "None" {

        }
        "OmniWheel_10" (
            prepend payload = @./configuration/OmniChassis_Wheel1_OmniWheel_10.usd@
        ) {
            prepend rel isaac:physics:robotJoints = </OmniChassis/OmniWheel_10>
            prepend rel isaac:physics:robotLinks = </OmniChassis/OmniWheel_10>

        }
    }
    variantSet "Wheel2" = {
        "None" {

        }
        "OmniWheel_10" (
            prepend payload = @./configuration/OmniChassis_Wheel2_OmniWheel_10.usd@
        ) {
            prepend rel isaac:physics:robotJoints = </OmniChassis/OmniWheel_11>
